<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A237E">

    <TextView
        android:id="@+id/tvCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Warning 1 of 6"
        android:textColor="#90CAF9"
        android:textSize="14sp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvWarnTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stay Focused! 🎯"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="24dp"/>

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFCC80"
        android:textSize="13sp"
        android:paddingBottom="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1E2A80">

        <TextView
            android:id="@+id/tvWarnMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text=""
            android:textColor="#E8EAF6"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"/>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnGoBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🎯 Return to Work"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Dismiss (Warning 2 next)"
        android:backgroundTint="#455A64"
        android:textColor="#FFFFFF"
        android:textSize="13sp"/>

</LinearLayout>
