<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#212121">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvGameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠 Mind Challenge"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱ 90s"
            android:textColor="#90CAF9"
            android:textSize="16sp"
            android:paddingBottom="20dp"/>

        <!-- MATH GAME -->
        <LinearLayout
            android:id="@+id/llMathGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1E2A2A">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingBottom="16dp"/>
                    <EditText
                        android:id="@+id/etAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Your answer"
                        android:inputType="numberSigned"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#757575"
                        android:backgroundTint="#4CAF50"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:paddingBottom="8dp"/>
                    <Button
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Submit Answer ✓"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ Correct: 0"
                        android:textColor="#90CAF9"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- MEMORY GAME -->
        <LinearLayout
            android:id="@+id/llMemoryGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1E1A2E">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/tvMemPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Memorise these numbers!"
                        android:textColor="#E8EAF6"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:paddingBottom="12dp"/>
                    <TextView
                        android:id="@+id/tvMemDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFEB3B"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingBottom="12dp"
                        android:letterSpacing="0.3"/>
                    <EditText
                        android:id="@+id/etMemAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. 3 7 1 4"
                        android:inputType="text"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#757575"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:visibility="gone"/>
                    <Button
                        android:id="@+id/btnMemSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Check Memory ✓"
                        android:backgroundTint="#7C4DFF"
                        android:textColor="#FFFFFF"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- RESULT -->
        <LinearLayout
            android:id="@+id/llResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1B5E20">
                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnDone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎯 Return to Work"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
